# ClaimLens AI — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI analysis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000

# Access password (protects the app behind a login screen)
# Remove or leave empty to disable password protection
ACCESS_PASSWORD=changeme
